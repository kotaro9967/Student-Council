---
import { Header } from '../components/Header';
import { Hero } from '../components/Hero';
import { Circles } from '../components/Circles';
import QuickAccess from '../components/QuickAccess.astro';
import News from '../components/News.astro';
import Footer from '../components/Footer.astro';

import '../styles/global.css';
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>東京理科大学 学友会</title>
  </head>
  <body class="bg-zinc-50 font-['Noto_Sans_JP'] overflow-x-hidden">
    <Header client:load />
    
    <main>
      <Hero client:load />
      <QuickAccess />
      <Circles client:visible />
      <News />
    </main>

    <Footer />

    {/* ⭕️ GSAP ScrollTriggerの登録用スクリプト */}
    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      // ScrollTriggerプラグインをGSAPに登録
      gsap.registerPlugin(ScrollTrigger);

      // (オプション) GSAPのグローバル設定（例：スクロールの滑らかさ）
      // ScrollTrigger.config({ limitCallbacks: true });
    </script>
  </body>
</html>
---
import { ArrowRight } from 'lucide-react';

const NEWS_DATA = [
  { date: '2026.03.15', category: '重要', title: '新入生歓迎会のスケジュールについて' },
  { date: '2026.03.10', category: 'お知らせ', title: '施設予約システムのメンテナンスのお知らせ' },
  { date: '2026.03.05', category: '活動報告', title: '令和7年度 春季総会のご報告' },
  { date: '2026.02.28', category: '募集', title: '学友会 新規スタッフ募集のお知らせ' },
];
---

<section id="news" class="py-24 md:py-32 bg-white text-zinc-900 overflow-hidden">
  <div class="container mx-auto px-6 md:px-12">
    <div class="mb-16 md:mb-24 flex flex-col items-center news-title scroll-reveal opacity-0">
      <h2 class="text-3xl md:text-5xl font-[Noto_Serif_JP] tracking-widest mb-4">
        News
      </h2>
      <p class="text-zinc-500 font-['Noto_Serif_JP'] tracking-wider text-sm md:text-base">
        お知らせ
      </p>
    </div>

    <div class="max-w-4xl mx-auto border-t border-zinc-200 news-list">
      {NEWS_DATA.map((item) => (
        <a
          href="#"
          class="scroll-reveal opacity-0 group flex flex-col md:flex-row md:items-center py-6 border-b border-zinc-200 hover:bg-zinc-50 px-4"
        >
          <div class="flex items-center gap-6 md:w-1/3 mb-4 md:mb-0">
            <span class="font-['Noto_Sans_JP'] text-zinc-500 text-sm tracking-widest">{item.date}</span>
            <span class="font-[Noto_Serif_JP] text-xs px-3 py-1 border border-zinc-300 rounded-full text-zinc-600 group-hover:bg-zinc-900 group-hover:text-white transition-colors duration-300">
              {item.category}
            </span>
          </div>
          <div class="md:w-2/3 flex justify-between items-center">
            <h3 class="font-[Noto_Serif_JP] text-base md:text-lg tracking-wider group-hover:translate-x-2 transition-transform duration-500">
              {item.title}
            </h3>
            <ArrowRight size={16} className="text-zinc-400 group-hover:text-zinc-900 opacity-0 group-hover:opacity-100 transition-all duration-300" />
          </div>
        </a>
      ))}
    </div>

    <div class="mt-16 text-center news-view-all scroll-reveal opacity-0">
      <a
        href="#"
        class="inline-flex items-center gap-4 text-sm font-['Noto_Serif_JP'] tracking-widest border-b border-zinc-900 pb-1 hover:text-zinc-600 hover:border-zinc-600 transition-colors"
      >
        View All
        <ArrowRight size={14} className="group-hover:translate-x-1 transition-transform" />
      </a>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const ctx = gsap.context(() => {
    gsap.to(".news-title", {
      opacity: 1, y: 0, duration: 1, ease: "power2.out",
      scrollTrigger: { trigger: ".news-title", start: "top 80%", toggleActions: "play none none reverse" }
    });
    gsap.to(".news-list .scroll-reveal", {
      opacity: 1, y: 0, duration: 1, stagger: 0.2, ease: "power2.out",
      scrollTrigger: { trigger: ".news-list", start: "top 70%", toggleActions: "play none none reverse" }
    });
    gsap.to(".news-view-all", {
      opacity: 1, duration: 1, delay: 0.5, ease: "power2.out",
      scrollTrigger: { trigger: ".news-view-all", start: "top 90%", toggleActions: "play none none reverse" }
    });
  });

  document.addEventListener('astro:before-swap', () => ctx.revert());
</script>
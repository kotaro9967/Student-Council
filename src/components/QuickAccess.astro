---
import { ArrowRight } from 'lucide-react';

const NEWS_DATA = [
  { date: '2026.03.15', category: '重要', title: '新入生歓迎会のスケジュールについて' },
  { date: '2026.03.10', category: 'お知らせ', title: '施設予約システムのメンテナンスのお知らせ' },
  { date: '2026.03.05', category: '活動報告', title: '令和7年度 春季総会のご報告' },
  { date: '2026.02.28', category: '募集', title: '学友会 新規スタッフ募集のお知らせ' },
];
---

<section id="news" class="py-24 md:py-32 bg-white text-zinc-900">
  <div class="container mx-auto px-6 md:px-12">
    <div class="mb-16 md:mb-24 flex flex-col items-center scroll-reveal opacity-0 translate-y-4 transition-all duration-700 ease-out">
      <h2 class="text-3xl md:text-5xl font-[Noto_Serif_JP] tracking-widest mb-4">
        News
      </h2>
      <p class="text-zinc-500 font-['Noto_Serif_JP'] tracking-wider text-sm md:text-base transition-delay-100">
        お知らせ
      </p>
    </div>

    <div class="max-w-4xl mx-auto border-t border-zinc-200">
      {NEWS_DATA.map((item, idx) => (
        <a
          href="#"
          class="scroll-reveal opacity-0 translate-y-4 transition-all duration-700 ease-out group flex flex-col md:flex-row md:items-center py-6 border-b border-zinc-200 hover:bg-zinc-50 px-4"
          style={`transition-delay: ${idx * 100}ms;`}
        >
          <div class="flex items-center gap-6 md:w-1/3 mb-4 md:mb-0">
            <span class="font-['Noto_Sans_JP'] text-zinc-500 text-sm tracking-widest">{item.date}</span>
            <span class="font-[Noto_Serif_JP] text-xs px-3 py-1 border border-zinc-300 rounded-full text-zinc-600 group-hover:bg-zinc-900 group-hover:text-white transition-colors duration-300">
              {item.category}
            </span>
          </div>
          <div class="md:w-2/3 flex justify-between items-center">
            <h3 class="font-[Noto_Serif_JP] text-base md:text-lg tracking-wider group-hover:translate-x-2 transition-transform duration-500">
              {item.title}
            </h3>
            <ArrowRight size={16} className="text-zinc-400 group-hover:text-zinc-900 opacity-0 group-hover:opacity-100 transition-all duration-300" />
          </div>
        </a>
      ))}
    </div>

    <div class="mt-16 text-center scroll-reveal opacity-0 transition-all duration-700 delay-300">
      <a
        href="#"
        class="inline-flex items-center gap-4 text-sm font-['Noto_Serif_JP'] tracking-widest border-b border-zinc-900 pb-1 hover:text-zinc-600 hover:border-zinc-600 transition-colors"
      >
        View All
        <ArrowRight size={14} />
      </a>
    </div>
  </div>
</section>

<script>
  const newsObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.remove('opacity-0', 'translate-y-4');
        entry.target.classList.add('opacity-100', 'translate-y-0');
        newsObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('#news .scroll-reveal').forEach(el => newsObserver.observe(el));
</script>